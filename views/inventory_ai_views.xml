<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_inventory_ai_bot_tree" model="ir.ui.view">
        <field name="name">inventory.ai.bot.tree</field>
        <field name="model">inventory.ai.bot</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="view_inventory_ai_bot_form" model="ir.ui.view">
        <field name="name">inventory.ai.bot.form</field>
        <field name="model">inventory.ai.bot</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="status"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_inventory_ai_bot" model="ir.actions.act_window">
        <field name="name">Inventory AI Bot</field>
        <field name="res_model">inventory.ai.bot</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_inventory_ai_root" name="Inventory AI" sequence="10"/>
    <menuitem id="menu_inventory_ai_bot" name="AI Bots" parent="menu_inventory_ai_root" action="action_inventory_ai_bot" sequence="10"/>
</odoo>
